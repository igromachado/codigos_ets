   "source": [
    "import pandas as pd\n",
    "\n",
    "dados = pd.read_csv(\"bases/dados.csv\",encoding=\"latin-1\")\n",
    "\n",
    "AAA = dados[(dados[\"quartos\"] == 3) & (dados[\"bairro\"] == \"Tijuca\") & (dados[\"area\"] > 130)]\n",
    "certo = AAA[AAA['preco'] == AAA[\"preco\"].min()]\n",
    "\n",
    "certo"
   ]
  }
